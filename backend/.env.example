PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/busybeds
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

# Stripe (subscriptions + Connect for referral payouts)
STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (subscriptions)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# Set to true for sandbox (testing); omit or false for production
# PAYPAL_SANDBOX=true

# Flutterwave (subscriptions - cards, mobile money for African markets)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_SECRET_HASH=your_webhook_secret_hash
